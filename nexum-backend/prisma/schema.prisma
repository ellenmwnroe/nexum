generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// AS NOSSAS TABELAS (MODELS) COMEÇAM AQUI
// ------------------------------------------------------

model Office {
  id         String   @id @default(uuid())
  name       String
  cnpj       String?
  created_at DateTime @default(now())

  lawyers Lawyer[]
  cases   Case[]
}

model Lawyer {
  id         String   @id @default(uuid())
  office_id  String
  name       String
  email      String   @unique
  role       String
  created_at DateTime @default(now())

  office Office      @relation(fields: [office_id], references: [id])
  events CaseEvent[]
  cases  Case[]      @relation("AssignedLawyer")
}

model User {
  id         String   @id @default(uuid())
  name       String
  cpf        String   @unique
  rg         String?
  phone      String?
  email      String?
  created_at DateTime @default(now())

  addresses Address[]
  cases     Case[]
}

model Address {
  id           String @id @default(uuid())
  user_id      String
  cep          String
  full_address String

  user User @relation(fields: [user_id], references: [id])
}

model Case {
  id                 String    @id @default(uuid())
  user_id            String
  office_id          String
  assigned_lawyer_id String?
  company            String
  role               String
  admission_date     DateTime?
  resignation_date   DateTime?
  salary             Decimal?
  status             String    @default("NOVO")
  notes              String?  @db.Text
  created_at         DateTime  @default(now())

  user             User             @relation(fields: [user_id], references: [id])
  office           Office           @relation(fields: [office_id], references: [id])
  assigned_lawyer  Lawyer?          @relation("AssignedLawyer", fields: [assigned_lawyer_id], references: [id])
  triage_responses TriageResponse[]
  documents        Document[]
  analyses         Analysis[]
  events           CaseEvent[]
}

model TriageResponse {
  id         String   @id @default(uuid())
  case_id    String
  field_name String
  value      String
  created_at DateTime @default(now())

  case Case @relation(fields: [case_id], references: [id])
}

model Document {
  id         String   @id @default(uuid())
  case_id    String
  file_url   String
  type       String
  created_at DateTime @default(now())

  case Case @relation(fields: [case_id], references: [id])
}

model Analysis {
  id          String   @id @default(uuid())
  case_id     String
  type        String
  description String
  risk_score  Int
  created_at  DateTime @default(now())

  case Case @relation(fields: [case_id], references: [id])
}

model CaseEvent {
  id         String   @id @default(uuid())
  case_id    String
  lawyer_id  String
  action     String
  note       String?
  created_at DateTime @default(now())

  case   Case   @relation(fields: [case_id], references: [id])
  lawyer Lawyer @relation(fields: [lawyer_id], references: [id])
}